<div class="flex flex--col flex--stretch-x w--full h--full gap--none">
  {% if current and current.temperature %}
  <div class="flex gap--[16px]" style="flex:1;">
    <div class="flex flex--col flex--stretch-x flex--between gap--none pt--8" style="flex:64;">
      {% render "weather_current", current: current %}
      {% render "weather_hourly_chart", hourly: hourly, daily: daily, current_time: current.time, chart_height: 230 %}
    </div>
    <div class="flex flex--col flex--stretch-x pt--4 pr--1.5 pb--4 gap--none" style="flex:36;">
      {% render "weather_daily_bars_vertical", daily_entries: daily.entries, num_days: 6, current_temp: current.temperature %}
    </div>
  </div>
  {% else %}
  <div class="flex flex--col flex--center-y gap--none" style="flex:1;">
    <img src="https://bmcdn.nl/assets/weather-icons/v3.0/line/svg/not-available.svg" class="w--24 h--24" style="opacity:0.4;">
    <div class="title mt--4" data-pixel-perfect="true">No weather data available.</div>
  </div>
  {% endif %}
  {% render "title_bar", plugin_name: trmnl.plugin_settings.instance_name, updated_at: current.time, icon_class: current.icon_class %}
</div>
