<div class="flex flex--col flex--stretch-x w--full h--full gap--none">
  {% if current and current.temperature %}
  <div class="flex flex--col flex--stretch-x pt--2 gap--none" style="flex:1;">
    {% render "weather_current_compact", current: current %}
    <div class="pb--2 pl--2 pr--1.5" style="flex:1; min-height:0;">
      {% render "weather_daily_bars_vertical", daily_entries: daily.entries, num_days: 5, current_temp: current.temperature %}
    </div>
  </div>
  {% else %}
  <div class="flex flex--col flex--center-y gap--none" style="flex:1;">
    <img src="https://bmcdn.nl/assets/weather-icons/v3.0/line/svg/not-available.svg" class="w--20 h--20" style="opacity:0.4;">
    <div class="title mt--4" data-pixel-perfect="true">No weather data available.</div>
  </div>
  {% endif %}
  <div>
    {% render "title_bar", plugin_name: trmnl.plugin_settings.instance_name, updated_at: current.time, icon_class: current.icon_class %}
  </div>
</div>
