{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "echo 'Invoke the trmnl-dev skill now to load the TRMNL plugin development context.'",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(curl:*)",
      "Bash(sleep:*)",
      "Bash(playwright-cli:*)",
      "Bash(tail:*)",
      "Bash(bash tools/build-preview.sh:*)",
      "Skill(playwright-cli)",
      "WebFetch(domain:docs.trmnl.com)",
      "WebFetch(domain:docs.usetrmnl.com)",
      "WebFetch(domain:erikflowers.github.io)",
      "WebFetch(domain:help.usetrmnl.com)",
      "WebFetch(domain:help.trmnl.com)",
      "WebFetch(domain:open-meteo.com)",
      "WebFetch(domain:trmnl.com)",
      "WebFetch(domain:usetrmnl.com)",
      "WebFetch(domain:127.0.0.1)"
    ]
  }
}
